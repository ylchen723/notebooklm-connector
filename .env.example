# notebooklm-connector 環境變數範例
# 複製此檔為 .env 並填上你自己的值。.env 不該進版控（已列在 .gitignore）。

# 你的 NotebookLM notebook URL（可選；若你常用某一本，先填好可加速）
# 從瀏覽器網址列複製，例如：
# NOTEBOOK_URL=https://notebooklm.google.com/notebook/your-notebook-id
NOTEBOOK_URL=

# nlm CLI 的安裝路徑（若 PATH 找不到 nlm，填這個）
# 安裝後可用 `which nlm` 查路徑
# NLM_BIN=/usr/local/bin/nlm
NLM_BIN=

# 預設輸出目錄（若你會用 ExportKit 或 nlm download）
# OUTPUT_DIR=./notebooklm-exports
OUTPUT_DIR=
